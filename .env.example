# ============================================================
# PIPS DOLLAR PRINTER — Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# ------------------------------------------------------------
# Supabase (required)
# Get these from: https://app.supabase.com → Project Settings → API
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ------------------------------------------------------------
# Deriv Affiliate Link (required for affiliate tracking)
# Get from: https://affiliates.deriv.com
# Example: https://track.deriv.com/_abc123/1/
# ------------------------------------------------------------
NEXT_PUBLIC_DERIV_AFFILIATE_LINK=https://deriv.partners/rx?sidc=FA33FFDD-3AFC-47A5-BDD5-E838068CEE7A&utm_campaign=dynamicworks&utm_medium=affiliate&utm_source=CU334550

# ------------------------------------------------------------
# M-Pesa Payment (required for Pro/Elite upgrades)
# NEXT_PUBLIC_MPESA_TILL: Your M-Pesa Buy Goods Till Number
# NEXT_PUBLIC_WHATSAPP_NUMBER: Full number with country code, no +
# ------------------------------------------------------------
NEXT_PUBLIC_MPESA_TILL=
NEXT_PUBLIC_WHATSAPP_NUMBER=254700000000

# ------------------------------------------------------------
# Community / Social Links
# Leave blank to automatically hide the section/link
# ------------------------------------------------------------
NEXT_PUBLIC_TELEGRAM_GROUP_URL=
NEXT_PUBLIC_TELEGRAM_URL=
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_YOUTUBE_URL=
NEXT_PUBLIC_TIKTOK_URL=
NEXT_PUBLIC_DISCORD_URL=

# ------------------------------------------------------------
# Platform Config
# ------------------------------------------------------------
NEXT_PUBLIC_DEMO_VIDEO_URL=
NEXT_PUBLIC_SITE_URL=https://pipsdollarprinter.com

# ------------------------------------------------------------
# Admin (server-side only — never expose to client)
# ------------------------------------------------------------
ADMIN_PASSWORD=
